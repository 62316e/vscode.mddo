{
  "name": "mddo",
  "displayName": "mddo",
  "description": "Decorate Markdown todo statuses and cycle them with a keyboard shortcut.",
  "version": "0.0.2",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/62316e/vscode.mddo.git"
  },
  "bugs": {
    "url": "https://github.com/62316e/vscode.mddo/issues"
  },
  "homepage": "https://github.com/62316e/vscode.mddo#readme",
  "engines": {
    "vscode": "^1.119.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "publisher": "62316e",
  "keywords": [
    "markdown",
    "todo",
    "task-list",
    "checkbox",
    "decorations"
  ],
  "galleryBanner": {
    "color": "1f2937",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "mddo",
      "properties": {
        "mddo.decorationScope": {
          "type": "string",
          "default": "narrow",
          "enum": [
            "narrow",
            "wholeLine"
          ],
          "enumDescriptions": [
            "Decorate only the [ ], [+], or [-] status token.",
            "Decorate from the status token through the end of the line."
          ],
          "description": "Controls how much of a Markdown todo line is decorated."
        },
        "mddo.colors.todo": {
          "type": "string",
          "default": "#9ca3af",
          "format": "color-hex",
          "description": "Color used for [ ] todo markers."
        },
        "mddo.colors.completed": {
          "type": "string",
          "default": "#22c55e",
          "format": "color-hex",
          "description": "Color used for [+] completed markers."
        },
        "mddo.colors.rejected": {
          "type": "string",
          "default": "#f97316",
          "format": "color-hex",
          "description": "Color used for [-] rejected markers."
        }
      }
    },
    "commands": [
      {
        "command": "mddo.toggle",
        "title": "Toggle Markdown Todo Status"
      }
    ],
    "keybindings": [
      {
        "command": "mddo.toggle",
        "key": "alt+d",
        "mac": "alt+d",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.119.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}